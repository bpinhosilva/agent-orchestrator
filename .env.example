# Agent Orchestrator — environment variables
#
# Copy this file to .env and fill in the values.
# JWT_SECRET and JWT_REFRESH_SECRET are auto-generated for development
# when you run `npm run dev` or `npm run start:dev`.

# ── Required ──────────────────────────────────────────────────────────────────

# HS256 signing secret for access tokens (min 32 chars)
JWT_SECRET=

# HS256 signing secret for refresh tokens (min 32 chars)
JWT_REFRESH_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# For production, set this to your public domain(s).
# ALLOWED_ORIGINS=https://example.com

# ── Domain (Docker / Caddy) ───────────────────────────────────────────────────

# Hostname served by Caddy. Defaults to "localhost" in docker-compose.yml.
# Set to your public domain for external deployments.
# Caddy automatically provisions Let's Encrypt certs for real public domains.
# DOMAIN=example.com

# ── Database ──────────────────────────────────────────────────────────────────

# IMPORTANT: Change these values before deploying to production.
DB_TYPE=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=agent_orchestrator
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
# DB_LOGGING=false

# ── Features ──────────────────────────────────────────────────────────────────

# SCHEDULER_ENABLED=true
# SERVE_STATIC_UI=true
# CHECK_PENDING_MIGRATIONS_ON_STARTUP=false

# ── AI provider keys (optional) ───────────────────────────────────────────────

# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
