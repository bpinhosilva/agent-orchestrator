# Agent Orchestrator — environment variables
#
# Copy this file to .env and fill in the values.
# JWT_SECRET and JWT_REFRESH_SECRET are auto-generated for development
# when you run `npm run dev` or `npm run start:dev`.

# ── Required ──────────────────────────────────────────────────────────────────

# HS256 signing secret for access tokens (min 32 chars)
JWT_SECRET=

# HS256 signing secret for refresh tokens (min 32 chars)
JWT_REFRESH_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────

# DB_TYPE=sqlite           # sqlite (default for dev) or postgres
# DATABASE_URL=            # postgres connection string (required for postgres)
# DB_LOGGING=false

# ── Features ──────────────────────────────────────────────────────────────────

# SCHEDULER_ENABLED=true
# SERVE_STATIC_UI=true
# CHECK_PENDING_MIGRATIONS_ON_STARTUP=false

# ── AI provider keys (optional) ───────────────────────────────────────────────

# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
